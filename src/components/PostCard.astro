---
import type { Post } from '../lib/content';
import { formatDate, getPostUrl, getReadingTime } from '../lib/content';

interface Props {
	post: Post;
}

const { post } = Astro.props;
---

<article class="article-item">
	<a class="article-index" href={getPostUrl(post)} aria-label={post.data.title}>
		{post.data.category.slice(0, 2)}
	</a>
	<div>
		<h3 class="article-title">
			<a href={getPostUrl(post)}>{post.data.title}</a>
		</h3>
		<p class="article-summary">{post.data.description}</p>
		<div class="article-meta">
			<a class="pill" href={`/categories/${encodeURIComponent(post.data.category)}`}>{post.data.category}</a>
			<span>{getReadingTime(post.body)}</span>
			{post.data.tags.slice(0, 3).map((tag) => (
				<a href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
			))}
		</div>
	</div>
	<time class="article-date" datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
</article>
