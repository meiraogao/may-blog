---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getAllProjects, getPublishedPosts } from '../lib/content';

const posts = await getPublishedPosts();
const projects = await getAllProjects();
---

<BaseLayout title="项目" description="May 的开源项目、个人项目、小工具和 AI 产品设计案例。">
	<div class="container layout-grid">
		<div class="main-column">
			<header class="page-hero">
				<p class="eyebrow">Projects</p>
				<h1 class="page-title">项目</h1>
				<p class="page-description">这里记录正在构建的小工具、个人项目、开源实验，以及围绕 AI 产品设计的思考。</p>
			</header>
			<div class="article-list">
				{projects.map((project) => <ProjectCard project={project} compact />)}
			</div>
		</div>
		<Sidebar posts={posts} />
	</div>
</BaseLayout>
