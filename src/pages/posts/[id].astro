---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { render } from 'astro:content';
import {
	formatDate,
	getPostUrl,
	getPublishedPosts,
	getReadingTime,
	getRelatedPosts,
	type Post,
} from '../../lib/content';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	return posts.map((post, index) => ({
		params: { id: post.id },
		props: {
			post,
			posts,
			previousPost: posts[index + 1] || null,
			nextPost: posts[index - 1] || null,
		},
	}));
}

interface Props {
	post: Post;
	posts: Post[];
	previousPost: Post | null;
	nextPost: Post | null;
}

const { post, posts, previousPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const relatedPosts = getRelatedPosts(post, posts, 3);
const fallbackRelatedPosts = posts
	.filter((item) => item.id !== post.id && !relatedPosts.some((related) => related.id === item.id))
	.slice(0, Math.max(0, 3 - relatedPosts.length));
const recommendedPosts = [...relatedPosts, ...fallbackRelatedPosts];
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout title={post.data.title} description={post.data.description}>
	<div class="container">
		<article class="post-layout">
			<div class="main-column">
				<header class="post-header">
					<a class="pill" href={`/categories/${encodeURIComponent(post.data.category)}`}>{post.data.category}</a>
					<h1 class="post-title">{post.data.title}</h1>
					<p class="post-description">{post.data.description}</p>
					<div class="article-meta">
						<time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
						<span>{getReadingTime(post.body)}</span>
						{post.data.tags.map((tag) => (
							<a href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
						))}
					</div>
				</header>

				{toc.length > 0 && (
					<details class="mobile-toc">
						<summary>文章目录</summary>
						<ul class="toc-list">
							{toc.map((heading) => (
								<li>
									<a href={`#${heading.slug}`}>{heading.text}</a>
								</li>
							))}
						</ul>
					</details>
				)}

				<div class="prose">
					<Content />
				</div>

				<nav class="post-nav" aria-label="文章前后导航">
					{previousPost ? (
						<a href={getPostUrl(previousPost)}>
							<span>上一篇</span>
							<strong>{previousPost.data.title}</strong>
						</a>
					) : <span></span>}
					{nextPost ? (
						<a href={getPostUrl(nextPost)}>
							<span>下一篇</span>
							<strong>{nextPost.data.title}</strong>
						</a>
					) : <span></span>}
				</nav>

				{recommendedPosts.length > 0 && (
					<section class="section" aria-labelledby="related-title">
						<div class="section-head">
							<div>
								<p class="eyebrow">Related</p>
								<h2 class="section-title" id="related-title">相关文章</h2>
							</div>
						</div>
						<div class="article-list">
							{recommendedPosts.map((item) => <PostCard post={item} />)}
						</div>
					</section>
				)}
			</div>
			<aside>
				{toc.length > 0 && (
					<nav class="toc" aria-label="文章目录">
						<p class="toc-title">文章目录</p>
						<ul class="toc-list">
							{toc.map((heading) => (
								<li>
									<a href={`#${heading.slug}`}>{heading.text}</a>
								</li>
							))}
						</ul>
					</nav>
				)}
			</aside>
		</article>
	</div>
</BaseLayout>
